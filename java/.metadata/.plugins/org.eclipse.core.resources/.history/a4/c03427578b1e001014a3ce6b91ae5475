public class GestionClient implements OperationCommerciale{
	private int idClient;
	
	
	@Override
	public boolean passerCommande(int qte, int remise,  int idProduit) {
		try {
			Connection con = DriverManager.getConnection(DATABASE_URL, "root", "");
			Statement stat = null;
			ResultSet rs = null;
			
			stat = con.createStatement();
			rs = stat.executeQuery("SELECT id_commande from commande where (id_client = "+this.idClient+")");
			int idCom=0;	
			while(rs.next()) {
					idCom = rs.getInt(1);
			}
			
			
			if(stat.execute("INSERT INTO Commande(date, id_client) values (now(), "+this.idClient+") ")==false) {
				con = DriverManager.getConnection(DATABASE_URL, "root", "");
				stat = con.createStatement();
				
				if(stat.execute("INSERT INTO ligne_commande values ("+idCom+", "+idProduit+", "+qte+", "+remise+") ")==false) {
					return true;
				}
			}
		}catch(SQLException ex) {
			ex.printStackTrace();
		}
		return false;
	}

	@Override
	public boolean validerPaiemenr(int idCommande) {
		try {
			Connection con = DriverManager.getConnection(DATABASE_URL, "root", "");
			Statement stat = null;
			ResultSet rs = null;
			
			stat = con.createStatement();
				rs = stat.executeQuery("SELECT * from commande where (id_client = "+this.idClient+" AND id_commande = "+idCommande+" AND statut like 'En cours')");
				if(rs.next()) {
					if(stat.execute("UPDATE commande set statut = 'Valider' where id_commande like "+idCommande+"")==false) {
						return true;
					}
				}
			
		}catch(SQLException ex) {
			ex.printStackTrace();
		}
		return false;
	}

