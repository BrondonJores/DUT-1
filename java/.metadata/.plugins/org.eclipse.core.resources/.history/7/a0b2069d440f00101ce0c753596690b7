	public static ActionListener MenuSelect(JFrame displayWindow){
		ActionListener MenuSelect = new ActionListener() {

			@Override
			public void actionPerformed(ActionEvent e) {
				JMenuItem option = (JMenuItem)e.getSource();
				if(option.getText().equals(" Affichage de comptes")) {
					displayAffichage(displayWindow);
				}else if(option.getText().equals(" Rechercher un compte")) {
					Recherche(displayWindow);
				}else if(option.getText().equals(" Suppression de comptes")) {
					Supprimer(displayWindow);
				}else if(option.getText().equals(" Historique des opérations")) {
					displayOperation(displayWindow);
				}else if(option.getText().equals(" Modification de comptes")) {
					Modification(displayWindow);
				}else if(option.getText().equals(" Operations bancaires")) {
					OperationsBancaires(displayWindow);
				}
				
			}
		
		
		};
		return MenuSelect;
	}

