		HistoriqueDesOP.setForeground(new Color(255,255,255));
		
		Connection con = null;
		Statement stat = null;
		ResultSet result;
		ResultSetMetaData resultmeta;
		String displayResult= "";
		
		try {
	   		Class.forName(JDBC_DRIVER);
			con =  DriverManager.getConnection(DATABASE_URL, "root", "");
			stat = con.createStatement();
			
			int nbreid=0;
			
			result = stat.executeQuery("SELECT count(*) from Compte");
			if(result.next()) {
				nbreid = result.getInt(1);
			}
			result = stat.executeQuery("SELECT numCompte, nomProprietaire, Solde, Type_Compte from Compte");
			resultmeta = result.getMetaData();
			
			int column = resultmeta.getColumnCount();
			String[] head =  new String[column];
			
			for(int i=1; i<=column; i++) {
				head[i-1]= resultmeta.getColumnName(i);
			}
			displayResult += "\n----------------------------------------------------- ";
			displayResult += "----------------------------------------------------- \n";
			
			String[][] Data= new String[nbreid][column];
			while(result.next()) {
				for(int i=1; i<=column; i++) {
					Data[result.getRow()-1][i-1]= result.getObject(i)+"";
				}
			}
			
			JScrollPane tableau = tableDefaut(head,Data);
			
			
			JLabel Titre = new JLabel("Affichage de comptes");
			
			JPanel TitreETMenu =  new JPanel(new GridLayout(3,1));
			JPanel ResumeIntro = new JPanel(new GridLayout(3,1));
			JPanel StateBar = new JPanel(new GridLayout(1,1));
			
			JLabel State = new JLabel("Affichage de comptes");
			State.setForeground(Color.white);
			StateBar.setBackground(Color.GREEN);
			StateBar.add(State);
			
			TitreETMenu.add(MenuBar);
			TitreETMenu.add(Titre);
			
			JTextArea text = new JTextArea(displayResult);
			text.setEditable(false);
			text.setFocusable(false);
			
			JFrame displayWindowA =  new JFrame("Accueil");
			displayWindowA.setSize(1000,400);
			displayWindowA.setLayout(new BorderLayout());
			displayWindowA.add(TitreETMenu, BorderLayout.NORTH);
			displayWindowA.add(tableau,BorderLayout.CENTER);
			displayWindowA.add(StateBar, BorderLayout.SOUTH);
			displayWindowA.setVisible(true);
	   	} catch (SQLException e1) {
	
		e1.printStackTrace();
	   	} catch (ClassNotFoundException e1) {
			// TODO Auto-generated catch block
			e1.printStackTrace();
		}
		
	}
	

