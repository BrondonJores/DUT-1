		MenuBar.add(Menu);
		
		MenuBar.setBackground(new Color(255,255,255));
		
		HistoriqueDesOP.setForeground(new Color(255,255,255));
		
		Connection con = null;
		Statement stat = null;
		ResultSet result;
		ResultSetMetaData resultmeta;
		String displayResult= "";
		
		try {
	   		Class.forName(JDBC_DRIVER);
			con =  DriverManager.getConnection(DATABASE_URL, "root", "");
			stat = con.createStatement();
			
			double comptesolde=0;
			
			result = stat.executeQuery("SELECT numCompte, nomProprietaire, Solde, Type_Compte from Compte");
			resultmeta = result.getMetaData();
			
			int column = resultmeta.getColumnCount();
			for(int i=1; i<=column; i++) {
				displayResult += resultmeta.getColumnName(i) +"\t";
			}
			displayResult += "\n----------------------------------------------------- ";
			displayResult += "----------------------------------------------------- \n";
			
			while(result.next()) {
				for(int i=1; i<=column; i++) {
					displayResult += result.getObject(i) +"\t";
				}
				displayResult += "\n";
			}
	   	} catch (SQLException e1) {
	
		e1.printStackTrace();
	   	} catch (ClassNotFoundException e1) {
			// TODO Auto-generated catch block
			e1.printStackTrace();
		}
		
		JLabel Titre = new JLabel("Affichage de compte");
		
		JPanel TitreETMenu =  new JPanel(new GridLayout(3,1));
